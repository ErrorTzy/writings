    ],
    "showOverwriteConfirmation": true,
    "openOutputFile": true,
    "revealOutputFile": false,
    "suggestRuntimeEnvVariables": true,
    "preview": {
      "enabled": true,
      "debounceMs": 700,
      "odtAddon": {
        "enabled": false,
        "status": "not-installed"
      }
    }
  }
}